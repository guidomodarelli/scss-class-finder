{
  "name": "scss-class-finder",
  "publisher": "guidomodarelli",
  "displayName": "SCSS Class Finder",
  "description": "Find SCSS classes by their resolved selector, handling nesting and & (parent selector)",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:html",
    "onLanguage:scss",
    "onLanguage:sass",
    "onLanguage:css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/guidomodarelli/scss-class-finder"
  },
  "homepage": "https://github.com/guidomodarelli/scss-class-finder#readme",
  "bugs": {
    "url": "https://github.com/guidomodarelli/scss-class-finder/issues"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scssClassFinder.findClass",
        "title": "SCSS: Find Class by Resolved Selector"
      },
      {
        "command": "scssClassFinder.findClassUsages",
        "title": "SCSS: Find Class Usages in Code"
      }
    ],
    "configuration": {
      "title": "SCSS Class Finder",
      "properties": {
        "scssClassFinder.previewOnResultFocus": {
          "type": "boolean",
          "default": true,
          "description": "Automatically preview and reveal the selected result while navigating the results list."
        },
        "scssClassFinder.additionalClassNameHelpers": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional JSX/TSX helper names treated like clsx/classnames/cx when extracting CSS class usages."
        }
      }
    },
    "keybindings": [
      {
        "command": "scssClassFinder.findClass",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "scssClassFinder.findClassUsages",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u",
        "when": "editorLangId == scss || editorLangId == sass || editorLangId == css"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies",
    "publish:vsce": "npx @vscode/vsce publish --no-dependencies",
    "test:unit": "npm run compile && node --test test/*.test.js",
    "test:integration": "npm run compile && node ./test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
